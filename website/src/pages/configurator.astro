---
/**
 * CMP configuration builder with live banner preview and JSON export.
 * Lets website owners visually configure the NoCookie CMP plugin.
 */
import Base from "@/layouts/Base.astro";
import ConfigForm from "@/components/configurator/ConfigForm.astro";
import ConfigPreview from "@/components/configurator/ConfigPreview.astro";
---

<Base
  title="CMP Configurator - NoCookie"
  description="Visually configure the NoCookie CMP plugin with live preview and export."
>
  <section class="py-16 sm:py-24 px-4">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-3xl sm:text-4xl font-bold text-center mb-2">
        CMP Configurator
      </h1>
      <p class="text-muted text-center mb-10 max-w-2xl mx-auto">
        Build your cookie consent banner configuration visually.
        Preview the result and export the config for your site.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {/* Left: form */}
        <div class="space-y-8 overflow-y-auto">
          <ConfigForm />
        </div>

        {/* Right: preview + export (sticky) */}
        <div>
          <div class="lg:sticky lg:top-20 space-y-6">
            <ConfigPreview />
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="../scripts/configurator.ts"></script>
</Base>

---
/**
 * Landing page with hero, problem statement, solution overview,
 * developer section, and install CTA.
 */
import Base from "@/layouts/Base.astro";

const codeSnippet = `// .well-known/cookie-consent.json
{
  "version": "1.0",
  "categories": ["essential", "analytics"],
  "purposes": {
    "analytics": {
      "tool": "Plausible",
      "retention": "30d"
    }
  }
}`;

const solutions = [
  {
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
    title: "Extension",
    description: "Works now. Auto-handles cookie popups on 100+ CMPs using existing consent rules.",
  },
  {
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    title: "Open Standard",
    description: "Works better. Websites declare cookie consent preferences for machines to read.",
  },
  {
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    title: "AI Ready",
    description: "Works everywhere. AI agents can implement the standard on any website automatically.",
  },
];
---

<Base title="NoCookie - Set your cookie preferences once">
  {/* Hero */}
  <section id="install" class="py-20 sm:py-32 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">
        Set your cookie preferences once.
        <span class="text-primary"> We handle the rest.</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-muted max-w-2xl mx-auto">
        NoCookie automatically handles cookie consent popups across the web
        — respecting your privacy choices without the endless clicking.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://chrome.google.com/webstore"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-primary hover:bg-primary-dark text-white font-medium transition-colors"
        >
          Install Extension
        </a>
        <a
          href="#standard"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-white/20 hover:border-white/40 text-white font-medium transition-colors"
        >
          Read the Standard &rarr;
        </a>
      </div>
    </div>
  </section>

  {/* Problem */}
  <section class="py-16 sm:py-24 px-4 border-t border-white/10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold">
        You click through 50+ cookie popups per week.
      </h2>
      <p class="mt-6 text-lg text-muted max-w-2xl mx-auto">
        Every website shows a different popup. Different layouts, different
        dark patterns, different ways to reject tracking. GDPR gave you the
        right to choose — but exercising it shouldn't be a full-time job.
      </p>
    </div>
  </section>

  {/* Solution */}
  <section id="extension" class="py-16 sm:py-24 px-4 border-t border-white/10">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-14">
        Three layers. One goal.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {solutions.map((item) => (
          <div class="rounded-xl border border-white/10 bg-surface-light p-6 hover:border-primary/50 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-muted">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* For Developers */}
  <section id="developers" class="py-16 sm:py-24 px-4 border-t border-white/10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold">
            Like <code class="text-primary">robots.txt</code> for cookie consent.
          </h2>
          <p class="mt-6 text-lg text-muted">
            Drop a JSON file at <code class="text-primary/80">/.well-known/cookie-consent.json</code>
            and browsers, extensions, and AI agents will know exactly what cookies
            your site uses — no popups needed.
          </p>
          <a
            href="/standard"
            class="inline-flex items-center mt-6 text-primary hover:text-primary-dark font-medium transition-colors"
          >
            Read the specification &rarr;
          </a>
        </div>
        <div class="rounded-xl border border-white/10 bg-surface-light p-4 overflow-x-auto">
          <pre class="text-sm text-muted"><code>{codeSnippet}</code></pre>
        </div>
      </div>
    </div>
  </section>

  {/* Standard intro */}
  <section id="standard" class="py-16 sm:py-24 px-4 border-t border-white/10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold">
        An open standard for the web.
      </h2>
      <p class="mt-6 text-lg text-muted max-w-2xl mx-auto">
        NoCookie is not just an extension — it's a proposal to make cookie consent
        machine-readable. Website owners, CMP vendors, and browser makers can all
        participate. The standard is open, free, and MIT licensed.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://github.com/zentala/nocookie"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-white/20 hover:border-white/40 text-white font-medium transition-colors"
        >
          View on GitHub
        </a>
      </div>
    </div>
  </section>
</Base>

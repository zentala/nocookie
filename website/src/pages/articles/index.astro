---
/**
 * Article listing page showing all blog posts as cards
 * with title, date, description, and tag badges.
 */
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Base title="Articles - NoCookie" description="Insights on cookie consent automation, privacy standards, and browser extensions.">
  <section class="py-20 sm:py-28 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-center">
        Articles
      </h1>
      <p class="mt-4 text-lg text-muted text-center max-w-2xl mx-auto">
        Insights on cookie consent automation, privacy standards, and the future of browser-managed preferences.
      </p>

      <div class="mt-14 space-y-6">
        {articles.map((article) => (
          <a
            href={`/articles/${article.id}`}
            class="block rounded-xl border border-white/10 bg-surface-light p-6 hover:border-primary/50 transition-colors"
          >
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
              <h2 class="text-xl font-semibold text-white">
                {article.data.title}
              </h2>
              <time
                datetime={article.data.date.toISOString()}
                class="text-sm text-muted whitespace-nowrap"
              >
                {formatDate(article.data.date)}
              </time>
            </div>
            <p class="mt-3 text-muted line-clamp-2">
              {article.data.description}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {article.data.tags.map((tag: string) => (
                <span class="inline-block text-xs font-medium px-2.5 py-0.5 rounded-full bg-primary/10 text-primary border border-primary/20">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

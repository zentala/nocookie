---
/**
 * Categories section of the v1 specification.
 */
const categories = [
  {
    name: "essential",
    desc: "Strictly necessary cookies required for the site to function. Cannot be disabled. Examples: session tokens, CSRF tokens, load-balancer affinity.",
  },
  {
    name: "functional",
    desc: "Cookies that enhance site functionality but are not strictly necessary. Examples: language preferences, theme settings, saved form data.",
  },
  {
    name: "analytics",
    desc: "Cookies used to collect anonymous usage data. Examples: page views, session duration, traffic sources.",
  },
  {
    name: "marketing",
    desc: "Cookies used for advertising and retargeting. Examples: ad personalization, conversion tracking, cross-site identification.",
  },
  {
    name: "social-media",
    desc: "Cookies set by social media embeds and sharing widgets. Examples: Facebook Like buttons, Twitter embeds, YouTube players.",
  },
];
---

<section id="categories" class="mb-16">
  <h2 class="text-2xl font-bold text-white mb-4">7. Categories</h2>
  <p class="text-muted leading-relaxed mb-6">
    The standard defines five cookie categories. Every declaration must include
    <code class="text-primary bg-surface-light px-1.5 py-0.5 rounded text-sm">"essential"</code>.
    Additional categories should only be listed if the site actually uses cookies in
    that category.
  </p>
  <div class="space-y-4">
    {categories.map((cat) => (
      <div class="rounded-xl border border-white/10 bg-surface-light p-4">
        <h3 class="text-base font-semibold text-white mb-1">
          <code class="text-primary">{cat.name}</code>
        </h3>
        <p class="text-sm text-muted">{cat.desc}</p>
      </div>
    ))}
  </div>
</section>

---
/**
 * Site header with responsive navigation.
 * Includes logo, nav links, and mobile hamburger menu.
 */
const navLinks = [
  { label: "Extension", href: "/#extension" },
  { label: "Standard", href: "/#standard" },
  { label: "Validator", href: "/validator" },
  { label: "Configurator", href: "/configurator" },
  { label: "Articles", href: "/articles" },
  { label: "Developers", href: "/#developers" },
  { label: "GitHub", href: "https://github.com/zentala/nocookie", external: true },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-md border-b border-white/10">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-white tracking-tight">
      NoCookie
    </a>

    {/* Desktop nav */}
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-muted hover:text-white transition-colors"
            {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="#install"
          class="text-sm font-medium px-4 py-2 rounded-lg bg-primary hover:bg-primary-dark text-white transition-colors"
        >
          Install
        </a>
      </li>
    </ul>

    {/* Mobile hamburger */}
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-muted hover:text-white"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-surface/95 backdrop-blur-md">
    <ul class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block text-sm text-muted hover:text-white transition-colors py-1"
            {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="#install"
          class="block text-sm font-medium px-4 py-2 rounded-lg bg-primary text-white text-center"
        >
          Install Extension
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const icon = document.getElementById("menu-icon");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");

    if (!expanded) {
      icon?.setAttribute("d", "M6 18L18 6M6 6l12 12");
    } else {
      icon?.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
    }
  });

  // Close on link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      icon?.setAttribute("d", "M4 6h16M4 12h16M4 18h16");
    });
  });
</script>

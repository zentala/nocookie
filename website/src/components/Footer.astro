---
/**
 * Site footer with links and open source attribution.
 */
const linkGroups = [
  {
    title: "Product",
    links: [
      { label: "Extension", href: "#extension" },
      { label: "Standard", href: "#standard" },
      { label: "Guides", href: "#developers" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "GitHub", href: "https://github.com/zentala/nocookie", external: true },
      { label: "Specification", href: "/standard" },
      { label: "Cookie Consent JSON", href: "/.well-known/cookie-consent.json" },
    ],
  },
];
---

<footer class="border-t border-white/10 bg-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div>
        <p class="text-lg font-bold text-white mb-2">NoCookie</p>
        <p class="text-sm text-muted">
          Set your cookie preferences once.<br />
          Open source, MIT licensed.
        </p>
      </div>

      {linkGroups.map((group) => (
        <div>
          <p class="text-sm font-semibold text-white mb-3">{group.title}</p>
          <ul class="space-y-2">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted hover:text-white transition-colors"
                  {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 text-center text-sm text-muted">
      <p>&copy; {new Date().getFullYear()} NoCookie. Open source under MIT License.</p>
    </div>
  </div>
</footer>

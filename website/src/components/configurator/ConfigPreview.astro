---
/**
 * Live banner preview and export panel for the CMP configurator.
 * Shows a mock banner, generated JSON, and copy/download buttons.
 */
---

{/* Banner Preview */}
<div>
  <h2 class="text-lg font-semibold text-white mb-3">Preview</h2>
  <div
    id="preview-container"
    class="relative rounded-xl border border-white/10 bg-neutral-100 min-h-[280px] overflow-hidden"
  >
    <div id="preview-banner" class="absolute transition-all duration-300">
      {/* Banner HTML injected by script */}
    </div>
  </div>
</div>

{/* JSON Export */}
<div>
  <h2 class="text-lg font-semibold text-white mb-3">Config JSON</h2>
  <pre
    id="cfg-json-output"
    class="rounded-xl border border-white/10 bg-surface p-4 text-sm text-muted overflow-x-auto font-mono max-h-[300px] overflow-y-auto"
  ></pre>
  <div class="flex gap-3 mt-3">
    <button
      id="cfg-copy-btn"
      class="flex-1 px-4 py-2 rounded-lg bg-primary hover:bg-primary-dark text-white text-sm font-medium transition-colors"
    >
      Copy Config
    </button>
    <button
      id="cfg-download-btn"
      class="flex-1 px-4 py-2 rounded-lg border border-white/20 hover:border-white/40 text-white text-sm font-medium transition-colors"
    >
      Download JSON
    </button>
  </div>
</div>

{/* Script Tag */}
<div class="rounded-lg border border-white/10 bg-surface-light p-4">
  <p class="text-sm font-medium text-white mb-2">Add to your site</p>
  <p class="text-xs text-muted mb-3">
    Include the CMP plugin with your configuration.
    The banner will render automatically.
  </p>
  <pre
    id="cfg-script-tag"
    class="rounded-lg bg-surface p-3 text-xs text-muted font-mono overflow-x-auto"
  ></pre>
  <button
    id="cfg-copy-script-btn"
    class="mt-2 px-3 py-1.5 rounded-lg border border-white/20 hover:border-white/40 text-white text-xs font-medium transition-colors"
  >
    Copy Script Tag
  </button>
</div>
